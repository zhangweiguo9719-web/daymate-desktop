{
  "name": "daymate-desktop",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format:check": "prettier --check .",
    "version:check": "node scripts/check-version.mjs",
    "desktop:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-desktop.ps1 dev",
    "desktop:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-desktop.ps1 build",
    "desktop:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-desktop.ps1 check",
    "desktop:test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-desktop.ps1 test",
    "desktop:clippy": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-desktop.ps1 clippy"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "dayjs": "^1.11.21",
    "lucide-react": "^1.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.9.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
